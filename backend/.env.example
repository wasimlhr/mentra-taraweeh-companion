# Shared transcription keys (sadaka jariya — free mode in the app UI).
# Groq is tried first; OpenAI is used as failover when Groq rate-limits.
# Get Groq: https://console.groq.com/keys
# Get OpenAI: https://platform.openai.com/api-keys
SHARED_GROQ_KEY=gsk_your_groq_key_here
SHARED_OPENAI_KEY=sk_your_openai_key_here

# Per-session cap for shared-key mode (minutes). BYOK users are uncapped.
MAX_MIN_PER_SESSION=90

# Optional: Gemini API key for non-Quran detection (tasbeeh, takbeer)
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# Optional: mobile-only deployment mode (enforces phone mic in settings)
MOBILE_ONLY_MODE=false

# Server port (default: 3001)
PORT=3001

# ── Legacy / self-hosted Whisper (not required for Groq/OpenAI) ───────────────
# TRANSCRIPTION_PROVIDER=whisper
# HUGGINGFACE_TOKEN=hf_your_token_here
# WHISPER_ENDPOINT_URL=https://your-endpoint.us-east-1.aws.endpoints.huggingface.cloud
# USE_LOCAL_WHISPER=false
# ENDPOINT_ON_DEMAND_ENABLED=false
# WHISPER_PROBE_ON_INIT=true
